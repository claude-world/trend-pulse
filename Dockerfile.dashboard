FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src/ ./src/

RUN pip install --no-cache-dir -e ".[mcp,llm,dashboard]"

RUN mkdir -p /app/data
ENV TREND_PULSE_DB=/app/data/history.db

EXPOSE 8501

CMD ["streamlit", "run", "src/trend_pulse/dashboard/app.py", "--server.port=8501", "--server.address=0.0.0.0"]
